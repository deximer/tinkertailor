# Example environment file for QA and staging deployments.
# Copy to .env.qa or .env.staging and fill in real values.
# These files are gitignored — never commit secrets.
#
# Used by:
#   infra/deploy.sh qa --migrate   (reads DATABASE_URL to run migrations)
#   infra/deploy.sh staging        (reads NEXT_PUBLIC_* for flyctl --build-arg)

# Supabase connection string for the target environment.
# Required when running: ./infra/deploy.sh <env> --migrate
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Public Supabase URL exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon key (safe to expose in frontend bundles).
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
